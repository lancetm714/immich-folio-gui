# ── Gallery Configuration ──────────────────────────────────────
# Define which Immich albums to publish and how to organize them.
#
# Find album UUIDs in Immich: Albums → click album → UUID in the URL bar.
# Find asset UUIDs: click a photo → UUID in the URL bar.

# Hero image(s) shown on the homepage (Immich asset UUIDs).
# Use a single UUID for a static image, or a list for a crossfade carousel.
hero: 00000000-0000-0000-0000-000000000000
# hero:
#   - 00000000-0000-0000-0000-000000000000
#   - 11111111-1111-1111-1111-111111111111
#   - 22222222-2222-2222-2222-222222222222

# Standalone albums — shown directly on the homepage as cards
albums:
  - 11111111-1111-1111-1111-111111111111
  - 22222222-2222-2222-2222-222222222222

# Show camera/lens EXIF on photo hover (default: true)
# exifOnHover: false

# Photo grid layout — customize columns, gap, aspect ratio, and mode.
# grid:
#   columns: 3        # default: 3
#   gap: 12            # pixels, default: 12
#   aspectRatio: "1"   # "1", "3/2", "auto", etc. default: "1"
#   layout: masonry    # "masonry" or "uniform", default: "masonry"

# Subpages — group albums into collections at /subpage-slug/album-slug
subpages:
  - name: Japan
    grid:                  # override global grid for this subpage
      columns: 4
      layout: uniform
      aspectRatio: "3/2"
    albums:
      - 33333333-3333-3333-3333-333333333333  # Tokyo
      - 44444444-4444-4444-4444-444444444444  # Kyoto

  - name: Wedding – Smith
    password: clientpass123  # visitors must enter this to view
    albums:
      - 55555555-5555-5555-5555-555555555555

# Footer — optional minimal footer with social links
# footer:
#   name: John Doe
#   instagram: johndoe
#   email: hello@example.com
#   website: https://example.com

# ── Theme ─────────────────────────────────────────────────────
# Control the visual identity of your gallery. Use a preset name:
#   theme: studio     # Leica-inspired, red dot, passepartout frames, film grain
#   theme: minimal    # Swiss brutalist, fullbleed hero, true B&W, zero-gap grid
#   theme: editorial  # Cinematic magazine, warm charcoal, Bodoni serif, shadow frames
#   theme: classic    # Gilded gallery, gold accents, Cinzel headings, passepartout
#
# Or customize individual properties (defaults from the preset):
# theme:
#   preset: studio              # base preset to extend
#   accent: "#2563eb"           # brand/accent color
#   fonts:
#     heading: "Inter"          # Google Fonts name for headings
#     body: "Inter"             # body text
#     caption: "JetBrains Mono" # EXIF captions
#   radius: 8                   # border-radius in pixels (0 = sharp)
#   photoFrame: none            # "none" | "passepartout" | "shadow"
#   grain: false                # film grain overlay on photos
#   headerDot: false            # accent dot in the nav bar
#   heroStyle: split            # "split" | "fullbleed" | "minimal"
